# Copy this file to .env and fill in your values
# Usage: cp .env.example .env && source .env

# Required: Anthropic API key
export ANTHROPIC_API_KEY="sk-ant-..."

# Path to local clone of ia-ops-argo-app (the GitOps repo ArgoCD watches)
# Default: ../../ia-ops-argo-app relative to the agent/ directory
export ARGO_REPO="/path/to/ia-ops-argo-app"

# Optional: model override (default: claude-sonnet-4-6)
# export AGENT_MODEL="claude-opus-4-7"
